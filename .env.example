INFLUXDB_TOKEN=
INFLUXDB_URL=
INFLUXDB_ORG=
INFLUXDB_USER=
INFLUXDB_BUCKET=speedwatch
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=
# Falls back to system hostname if not set
DEVICE_HOST=
# Address where to host i located, if you are trcking multiple locations (selectable in Grafana)
DEVICE_ADDRESS=
# Enable file logging (true/false)
LOG=true
# Log rotation: max size in bytes before rotating (default 1MB), and number of backup files to keep
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=3
# Enable debug output to shell (true/false)
DEBUG=true
# Number of pings per host
PING_COUNT=10

# Number of preferred servers from speedtest -L when MONITOR_SERVER_IDS is empty
SERVER_COUNT=3
# Preferred server IDs for rotation (comma-separated). If set, rotates between these.
# If empty, first SERVER_COUNT servers from speedtest -L are used. Fallbacks are all remaining -L servers.
MONITOR_SERVER_IDS=

# Storage backend: influxdb (default) or sqlite
# influxdb: writes to InfluxDB Cloud; requires INFLUXDB_* keys above
# sqlite:   writes to var/speeds.db locally; view results with dashboard.py
STORAGE=influxdb

# SQLite mode only: port for dashboard.py
DASHBOARD_PORT=8080
# SQLite mode only: max rows to keep in speeds.db; oldest rows are trimmed on each write
SQLITE_MAX_ROWS=10000
